# ============================================================
#  AI Gmail Executive Assistant — Environment Variables
# ============================================================

# --- Gemini LLM -------------------------------------------------
GEMINI_API_KEY=AIzaSyBPUzzaR9adOR0uqdaMYi3AgDzm0-EvI-s
GEMINI_MODEL=gemini-2.5-flash

# --- Gmail / Google Calendar OAuth ------------------------------
# Path to the downloaded OAuth2 credentials JSON
GOOGLE_CREDENTIALS_PATH=credentials.json
# Token cache (auto-generated on first login)
GOOGLE_TOKEN_PATH=token.json
# Scopes — do not change unless you know what you're doing
GOOGLE_SCOPES=https://www.googleapis.com/auth/gmail.modify,https://www.googleapis.com/auth/calendar

# --- Database ---------------------------------------------------
# SQLite for local dev (default). Swap to postgres:// for production.
DATABASE_URL=sqlite:///./assistant.db

# --- ChromaDB ---------------------------------------------------
CHROMA_DB_PATH=./chroma_db

# --- Graph Memory -----------------------------------------------
GRAPH_MEMORY_PATH=./graph_memory.pkl

# --- Polling ---------------------------------------------------
# How often to check Gmail for new emails (seconds)
POLL_INTERVAL_SECONDS=60

# --- Optional Integrations (leave blank to disable) -------------
NOTION_TOKEN=
NOTION_DATABASE_ID=
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
TRELLO_API_KEY=
TRELLO_TOKEN=
TRELLO_LIST_ID=

# --- Frontend ---------------------------------------------------
# URL of the FastAPI backend (used by React frontend)
VITE_API_BASE_URL=http://localhost:8000
